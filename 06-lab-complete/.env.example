# Copy thành .env và điền giá trị thật
# ❌ KHÔNG commit file .env lên Git

# Server
HOST=0.0.0.0
PORT=8000
ENVIRONMENT=development
DEBUG=true

# App
APP_NAME=AI Agent
APP_VERSION=1.0.0

# LLM
OPENAI_API_KEY=
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
ENABLE_NEMO_GUARDRAILS=true

# Security — BẮT BUỘC thay trong production
JWT_SECRET=dev-jwt-secret-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
JWT_REFRESH_EXPIRE_MINUTES=10080
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=Admin@123456

# Rate & Budget
RATE_LIMIT_PER_MINUTE=10
DAILY_BUDGET_USD=5.0

# Storage
REDIS_URL=redis://localhost:6379/0
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION_AIR_RULES=airline_regulations

# Database MySQL
DATABASE_URL=mysql+pymysql://agent_user:agent_pass@mysql:3306/agent_db

# CORS
ALLOWED_ORIGINS=http://localhost:3000
