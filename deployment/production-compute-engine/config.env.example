# Copy file nay thanh config.env truoc khi deploy

# GCP
PROJECT_ID=your-gcp-project-id
ZONE=asia-southeast1-b
REGION=asia-southeast1

# Compute Engine
VM_NAME=ai-agent-vm
MACHINE_TYPE=e2-standard-2
BOOT_DISK_SIZE=30GB
FIREWALL_RULE=allow-ai-agent-http
NETWORK_TAG=ai-agent-web

# GitHub repo tren VM
REPO_URL=https://github.com/<your-user>/<your-repo>.git
REPO_DIR=$HOME/app
BRANCH=main
